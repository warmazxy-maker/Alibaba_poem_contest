[
    {
        "idx": 0,
        "que": "商女不知亡国恨，隔江犹唱后庭花。"
    },
    {
        "idx": 1,
        "que": "三春白雪归青冢，万里黄河绕黑山。"
    },
    {
        "idx": 2,
        "que": "昨夜上皇新授箓，太真含笑入帘来。"
    },
    {
        "idx": 3,
        "que": "姑苏城外寒山寺，夜半钟声到客船。"
    },
    {
        "idx": 4,
        "que": "纱窗日落渐黄昏，金屋无人见泪痕。"
    },
    {
        "idx": 5,
        "que": "朱雀桥边野草花，乌衣巷口夕阳斜。"
    },
    {
        "idx": 6,
        "que": "终是圣明天子事，景阳宫井又何人。"
    },
    {
        "idx": 7,
        "que": "日暮汉宫传蜡烛，轻烟散入五侯家。"
    },
    {
        "idx": 8,
        "que": "文翁翻教授，不敢倚先贤。"
    },
    {
        "idx": 9,
        "que": "襄阳好风日，留醉与山翁。"
    },
    {
        "idx": 10,
        "que": "复值接舆醉，狂歌五柳前。"
    },
    {
        "idx": 11,
        "que": "登舟望秋月，空忆谢将军。"
    },
    {
        "idx": 12,
        "que": "浮云游子意，落日故人情。"
    },
    {
        "idx": 13,
        "que": "薄宦梗犹泛，故园芜已平。"
    },
    {
        "idx": 14,
        "que": "对棋陪谢傅，把剑觅徐君。"
    },
    {
        "idx": 15,
        "que": "应共冤魂语，投诗赠汨罗。"
    },
    {
        "idx": 16,
        "que": "羊公碑尚在，读罢泪沾襟。"
    },
    {
        "idx": 17,
        "que": "忽逢青鸟使，邀入赤松家。"
    },
    {
        "idx": 18,
        "que": "金灶初开火，仙桃正发花。"
    },
    {
        "idx": 19,
        "que": "童颜若可驻，何惜醉流霞。"
    },
    {
        "idx": 20,
        "que": "地犹鄹氏邑，宅即鲁王宫。"
    },
    {
        "idx": 21,
        "que": "叹凤嗟身否，伤麟怨道穷。"
    },
    {
        "idx": 22,
        "que": "今看两楹奠，当与梦时同。"
    },
    {
        "idx": 23,
        "que": "势分三足鼎，业复五铢钱。"
    },
    {
        "idx": 24,
        "que": "凄凉蜀故妓，来舞魏宫前。"
    },
    {
        "idx": 25,
        "que": "谢公最小偏怜女，自嫁黔娄百事乖。"
    },
    {
        "idx": 26,
        "que": "邓攸无子寻知命，潘岳悼亡犹费词。"
    },
    {
        "idx": 27,
        "que": "野老与人争席罢，海鸥何事更相疑。"
    },
    {
        "idx": 28,
        "que": "刘郎已恨蓬山远，更隔蓬山一万重！"
    },
    {
        "idx": 29,
        "que": "贾氏窥帘韩掾少，宓妃留枕魏王才。"
    },
    {
        "idx": 30,
        "que": "徒令上将挥神笔，终见降王走传车。"
    },
    {
        "idx": 31,
        "que": "管乐有才原不忝，关张无命欲何如？"
    },
    {
        "idx": 32,
        "que": "地下若逢陈后主，岂宜重问后庭花。"
    },
    {
        "idx": 33,
        "que": "江山故宅空文藻，云雨荒台岂梦思。"
    },
    {
        "idx": 34,
        "que": "卧龙跃马终黄土，人事音书漫寂寥。"
    },
    {
        "idx": 35,
        "que": "可怜后主还祠庙，日暮聊为《梁甫吟》。"
    },
    {
        "idx": 36,
        "que": "机中锦字论长恨，楼上花枝笑独眠。"
    },
    {
        "idx": 37,
        "que": "为问元戎窦车骑，何时返旆勒燕然。"
    },
    {
        "idx": 38,
        "que": "少小虽非投笔吏，论功还欲请长缨。"
    },
    {
        "idx": 39,
        "que": "且欲近寻彭泽宰，陶然共醉菊花杯。"
    },
    {
        "idx": 40,
        "que": "关门令尹谁能识，河上仙翁去不回。"
    },
    {
        "idx": 41,
        "que": "晴川历历汉阳树，芳草萋萋鹦鹉洲。"
    },
    {
        "idx": 42,
        "que": "谁解乘舟寻范蠡，五湖烟水独忘机。"
    },
    {
        "idx": 43,
        "que": "苏武魂销汉使前，古祠高树两茫然。"
    },
    {
        "idx": 44,
        "que": "云边雁断胡天月，陇上羊归塞草烟。"
    },
    {
        "idx": 45,
        "que": "茂陵不见封侯印，空向秋波哭逝川。"
    },
    {
        "idx": 46,
        "que": "王濬楼船下益州，金陵王气黯然收。"
    },
    {
        "idx": 47,
        "que": "千寻铁锁沉江底，一片降幡出石头。"
    },
    {
        "idx": 48,
        "que": "献赋十年犹未遇，羞将白发对华簪。"
    },
    {
        "idx": 49,
        "que": "持谢邻家子，效颦安可希。"
    },
    {
        "idx": 50,
        "que": "既至金门远，孰云吾道非。"
    },
    {
        "idx": 51,
        "que": "终罢斯结庐，慕陶直可庶。"
    },
    {
        "idx": 52,
        "que": "汉皇重色思倾国，御宇多年求不得。"
    },
    {
        "idx": 53,
        "que": "杨家有女初长成，养在深闺人未识。"
    },
    {
        "idx": 54,
        "que": "金屋妆成娇侍夜，玉楼宴罢醉和春。"
    },
    {
        "idx": 55,
        "que": "蓬莱文章建安骨，中间小谢又清发。"
    },
    {
        "idx": 56,
        "que": "我本楚狂人，凤歌笑孔丘。"
    },
    {
        "idx": 57,
        "que": "脚著谢公屐，身登青云梯。"
    },
    {
        "idx": 58,
        "que": "不据山河据平地，长戈利矛日可麾。"
    },
    {
        "idx": 59,
        "que": "蔡女昔造胡笳声，一弹一十有八拍。"
    },
    {
        "idx": 60,
        "que": "郑国游人未及家，洛阳行子空叹息。"
    },
    {
        "idx": 61,
        "que": "鹿门月照开烟树，忽到庞公栖隐处。"
    },
    {
        "idx": 62,
        "que": "但使龙城飞将在，不教胡马度阴山。"
    },
    {
        "idx": 63,
        "que": "少年十五二十时，步行夺得胡马骑。"
    },
    {
        "idx": 64,
        "que": "射杀山中白额虎，肯数邺下黄须儿！"
    },
    {
        "idx": 65,
        "que": "卫青不败由天幸，李广无功缘数奇。"
    },
    {
        "idx": 66,
        "que": "誓令疏勒出飞泉，不似颍川空使酒。"
    },
    {
        "idx": 67,
        "que": "弹剑作歌奏苦声，曳裾王门不称情。"
    },
    {
        "idx": 68,
        "que": "行人刁斗风沙暗，公主琵琶幽怨多。"
    },
    {
        "idx": 69,
        "que": "闻道玉门犹被遮，应将性命逐轻车。"
    },
    {
        "idx": 70,
        "que": "念往昔，繁华竞逐，叹门外楼头，悲恨相续。"
    },
    {
        "idx": 71,
        "que": "故垒西边，人道是，三国周郎赤壁。"
    },
    {
        "idx": 72,
        "que": "遥想公瑾当年，小乔初嫁了，雄姿英发。"
    },
    {
        "idx": 73,
        "que": "风前横笛斜吹雨，醉里簪花倒著冠。"
    },
    {
        "idx": 74,
        "que": "瑶草一何碧，春入武陵溪。"
    },
    {
        "idx": 75,
        "que": "伊吕两衰翁，历遍穷通。"
    },
    {
        "idx": 76,
        "que": "吟笺赋笔，犹记燕台句。"
    },
    {
        "idx": 77,
        "que": "知谁伴、名园露饮，东城闲步。"
    },
    {
        "idx": 78,
        "que": "恐断红、尚有相思字，何由见得。"
    },
    {
        "idx": 79,
        "que": "归来三径重扫，松竹本吾家。"
    },
    {
        "idx": 80,
        "que": "镜湖元自属闲人，又何必、官家赐与。"
    },
    {
        "idx": 81,
        "que": "谁伴我，醉中舞。"
    },
    {
        "idx": 82,
        "que": "十年一梦扬州路。"
    },
    {
        "idx": 83,
        "que": "要斩楼兰三尺剑，遗恨琵琶旧语。"
    },
    {
        "idx": 84,
        "que": "纵收香藏镜，他年重到，人面桃花在否。"
    },
    {
        "idx": 85,
        "que": "剩喜燃犀处，骇浪与天浮。"
    },
    {
        "idx": 86,
        "que": "休说鲈鱼堪脍，尽西风，季鹰归未？"
    },
    {
        "idx": 87,
        "que": "可惜流年，忧愁风雨，树犹如此！"
    },
    {
        "idx": 88,
        "que": "待燃犀下看，凭栏却怕，风雷怒，鱼龙惨。"
    },
    {
        "idx": 89,
        "que": "马上琵琶关塞黑，更长门、翠辇辞金阙。"
    },
    {
        "idx": 90,
        "que": "将军百战身名裂。"
    },
    {
        "idx": 91,
        "que": "向河梁、回头万里，故人长绝。"
    },
    {
        "idx": 92,
        "que": "易水萧萧西风冷，满座衣冠似雪。"
    },
    {
        "idx": 93,
        "que": "知我者，二三子。"
    },
    {
        "idx": 94,
        "que": "一尊搔首东窗里。"
    },
    {
        "idx": 95,
        "que": "马作的卢飞快，弓如霹雳弦惊。"
    },
    {
        "idx": 96,
        "que": "斜阳草树，寻常巷陌，人道寄奴曾住。"
    },
    {
        "idx": 97,
        "que": "千古江山，英雄无觅，孙仲谋处。"
    },
    {
        "idx": 98,
        "que": "想当年，金戈铁马，气吞万里如虎。"
    },
    {
        "idx": 99,
        "que": "元嘉草草，封狼居胥，赢得仓皇北顾。"
    },
    {
        "idx": 100,
        "que": "可堪回首，佛狸祠下，一片神鸦社鼓。"
    },
    {
        "idx": 101,
        "que": "天下英雄谁敌手？曹刘。生子当如孙仲谋。"
    },
    {
        "idx": 102,
        "que": "大家齐唱《大风歌》，不日四方来贺。"
    },
    {
        "idx": 103,
        "que": "韦郎去也，怎忘得、玉环分付：第一是早早归来，怕红萼无人为主。"
    },
    {
        "idx": 104,
        "que": "新来雁阔云音，鸾分鉴影，无计重见。"
    },
    {
        "idx": 105,
        "que": "君去京东豪杰喜，想投戈、下拜真吾父。"
    },
    {
        "idx": 106,
        "que": "问当年、祖生去后，有人来否。"
    },
    {
        "idx": 107,
        "que": "何逊而今渐老，都忘却春风词笔。"
    },
    {
        "idx": 108,
        "que": "依稀记，曾请缨系粤，草檄征辽。"
    },
    {
        "idx": 109,
        "que": "谁信道凄凉今折腰。"
    },
    {
        "idx": 110,
        "que": "白发书生神州泪，尽凄凉、不向牛山滴。"
    },
    {
        "idx": 111,
        "que": "常恨世人新意少，爱说南朝狂客。"
    },
    {
        "idx": 112,
        "que": "苔枝缀玉，有翠禽小小，枝上同宿。"
    },
    {
        "idx": 113,
        "que": "犹记深宫旧事，那人正睡里，飞近蛾绿。"
    },
    {
        "idx": 114,
        "que": "莫似春风，不管盈盈，早与安排金屋。"
    },
    {
        "idx": 115,
        "que": "易挑锦妇机中字。"
    },
    {
        "idx": 116,
        "que": "过垂虹亭下，系扁舟，鲈堪煮。"
    },
    {
        "idx": 117,
        "que": "短梦依然江表，老泪洒西州。"
    },
    {
        "idx": 118,
        "que": "载取白云归去，问谁留楚佩，弄影中洲？"
    },
    {
        "idx": 119,
        "que": "空怀感，有斜阳处，却怕登楼。"
    },
    {
        "idx": 120,
        "que": "芦叶蓬舟千重，菰菜莼羹一梦，无语寄归鸿。"
    },
    {
        "idx": 121,
        "que": "溯红渐、招入仙溪，锦儿偷寄幽素。"
    },
    {
        "idx": 122,
        "que": "幻苍崖云树，名娃金屋，残霸宫城。"
    },
    {
        "idx": 123,
        "que": "宫里吴王沉醉，倩五湖倦客，独钓醒醒。"
    },
    {
        "idx": 124,
        "que": "更有谁、磻溪未遇，傅岩未起。"
    }
]